{
  "name": "User",
  "type": "object",
  "properties": {
    "tenant_id": {
      "type": "string",
      "description": "Primary tenant association"
    },
    "user_role": {
      "type": "string",
      "enum": [
        "tenant_owner",
        "tenant_admin",
        "client_admin",
        "supervisor",
        "cleaner",
        "auditor"
      ],
      "default": "cleaner",
      "description": "System role"
    },
    "phone": {
      "type": "string"
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "client_access": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "client_id": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        }
      },
      "description": "Array of client IDs and roles user can access"
    },
    "last_login_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}