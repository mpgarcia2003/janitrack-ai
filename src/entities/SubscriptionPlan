{
  "name": "SubscriptionPlan",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Plan name (e.g., Free, Pro, Enterprise)"
    },
    "slug": {
      "type": "string",
      "description": "URL-friendly identifier"
    },
    "price_monthly": {
      "type": "number",
      "description": "Monthly price in dollars"
    },
    "price_yearly": {
      "type": "number",
      "description": "Yearly price in dollars"
    },
    "stripe_price_id_monthly": {
      "type": "string",
      "description": "Stripe Price ID for monthly billing"
    },
    "stripe_price_id_yearly": {
      "type": "string",
      "description": "Stripe Price ID for yearly billing"
    },
    "limits": {
      "type": "object",
      "description": "Usage limits",
      "properties": {
        "max_clients": {
          "type": "number"
        },
        "max_areas": {
          "type": "number"
        },
        "max_users": {
          "type": "number"
        },
        "max_projects": {
          "type": "number"
        },
        "max_inventory_items": {
          "type": "number"
        }
      }
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of included features"
    },
    "active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "name",
    "slug",
    "price_monthly"
  ]
}