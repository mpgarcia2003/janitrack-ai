{
  "name": "Feedback",
  "type": "object",
  "properties": {
    "tenant_id": {
      "type": "string"
    },
    "client_id": {
      "type": "string"
    },
    "area_id": {
      "type": "string",
      "description": "Optional - null for facility-wide feedback"
    },
    "rating": {
      "type": "number",
      "minimum": 1,
      "maximum": 5,
      "description": "1-5 star rating"
    },
    "comment": {
      "type": "string",
      "description": "Optional text feedback"
    },
    "submitted_by_name": {
      "type": "string",
      "description": "Optional name of person submitting"
    },
    "submitted_by_email": {
      "type": "string",
      "description": "Optional email"
    },
    "ip_address": {
      "type": "string"
    },
    "user_agent": {
      "type": "string"
    },
    "feedback_timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "tenant_id",
    "client_id",
    "rating",
    "feedback_timestamp"
  ]
}