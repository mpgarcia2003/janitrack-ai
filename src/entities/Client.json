{
  "name": "Client",
  "type": "object",
  "properties": {
    "tenant_id": {
      "type": "string",
      "description": "Reference to Tenant entity"
    },
    "name": {
      "type": "string",
      "description": "Client location name"
    },
    "code": {
      "type": "string",
      "description": "Short code for URLs and QR codes"
    },
    "address": {
      "type": "string"
    },
    "timezone": {
      "type": "string",
      "default": "America/New_York"
    },
    "contact_name": {
      "type": "string"
    },
    "contact_email": {
      "type": "string"
    },
    "contact_phone": {
      "type": "string"
    },
    "project_qr_token": {
      "type": "string",
      "description": "Unique token for project submission QR code"
    },
    "feedback_qr_token": {
      "type": "string",
      "description": "Unique token for facility-wide feedback QR code"
    },
    "inventory_qr_token": {
      "type": "string",
      "description": "Unique token for inventory management QR code"
    },
    "sheets_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Enable Google Sheets sync"
    },
    "sheet_id": {
      "type": "string",
      "description": "Google Sheet ID for exports"
    },
    "active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "tenant_id",
    "name",
    "code"
  ]
}