{
  "name": "InventoryItem",
  "type": "object",
  "properties": {
    "tenant_id": {
      "type": "string"
    },
    "client_id": {
      "type": "string"
    },
    "sku": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "cleaning_supplies",
        "paper_products",
        "chemicals",
        "equipment",
        "other"
      ],
      "default": "cleaning_supplies"
    },
    "unit": {
      "type": "string",
      "enum": [
        "ea",
        "roll",
        "bottle",
        "case",
        "gallon",
        "box"
      ],
      "default": "ea"
    },
    "par_level": {
      "type": "number",
      "description": "Target inventory level"
    },
    "on_hand": {
      "type": "number",
      "default": 0,
      "description": "Current quantity"
    },
    "reorder_point": {
      "type": "number",
      "description": "Alert when below this threshold"
    },
    "vendor": {
      "type": "string"
    },
    "vendor_sku": {
      "type": "string"
    },
    "unit_cost": {
      "type": "number"
    },
    "last_count_at": {
      "type": "string",
      "format": "date-time"
    },
    "active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "tenant_id",
    "client_id",
    "sku",
    "name"
  ]
}