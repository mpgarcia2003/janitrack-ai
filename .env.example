# ============================================================
# JaniTrackAI environment variables
# ============================================================
# Copy this file to `.env.local` for local development, or paste these
# keys into your Vercel project's Environment Variables tab.

# --- Supabase (client + server) -----------------------------
# Required. Find both at https://app.supabase.com/project/<id>/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase service-role (SERVER ONLY, NEVER expose) ------
# Read from Supabase Dashboard → Settings → API → "service_role secret".
# Add this to Vercel as a Production env var. DO NOT prefix with VITE_
# (that would expose it to the browser bundle).
SUPABASE_SERVICE_ROLE_KEY=

# --- Public app URL (optional) ------------------------------
# Used to generate the URL printed on QR codes. Defaults to
# window.location.origin if unset, which is correct for a single-domain
# Vercel deploy.
VITE_PUBLIC_APP_URL=

# --- Stripe (server-only, for billing) ----------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
