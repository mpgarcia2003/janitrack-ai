# ============================================================
# JaniTrackAI environment variables
# ============================================================
# Copy this file to `.env.local` for local development, or paste
# these keys into your Vercel project's Environment Variables tab.

# --- Required ---

# base44 application id (find this in the base44 dashboard for your app)
VITE_BASE44_APP_ID=

# base44 backend URL (default: https://app.base44.com). Override only if you're
# pointing at a staging instance.
VITE_BASE44_BACKEND_URL=https://app.base44.com

# --- Optional ---

# Override for the public-QR origin. Defaults to window.location.origin, which
# is correct for a single-domain deploy. Set this if you want printed QR codes
# to resolve to a different subdomain (e.g. https://scan.your-domain.com).
VITE_PUBLIC_APP_URL=

# ============================================================
# Cloud functions (Deno, deployed via base44) — these are
# server-side env vars, NOT shipped to the browser, so they do
# NOT need the VITE_ prefix. Set them in the base44 dashboard
# under Functions → Environment.
# ============================================================
#
# BASE44_APP_ID         — same as VITE_BASE44_APP_ID
# STRIPE_SECRET_KEY     — sk_live_… (or sk_test_… for staging)
# STRIPE_WEBHOOK_SECRET — whsec_…
